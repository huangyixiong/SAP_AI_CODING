    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.10.1",
    "openai": "^6.34.0",
    "p-queue": "^8.0.1",
    "prisma": "^7.7.0",
